+
 // free a proc structure and the data hanging from it,
 // including user pages.
 // p->lock must be held.
@@ -421,44 +450,116 @@ kwait(uint64 addr)
 void
 scheduler(void)
 {
-  struct proc *p;
   struct cpu *c = mycpu();
-
   c->proc = 0;
+
   for(;;){
-    // The most recent process to run may have had interrupts
-    // turned off; enable them to avoid a deadlock if all
-    // processes are waiting. Then turn them back off
-    // to avoid a possible race between an interrupt
-    // and wfi.
     intr_on();
-    intr_off();
 
+#ifdef FCFS
+    struct proc *p;
+    struct proc *earliest = 0;
+
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        if(!earliest || p->creation_time < earliest->creation_time) {
+          if(earliest) release(&earliest->lock);
+          earliest = p;
+        } else {
+          release(&p->lock);
+        }
+      } else {
+        release(&p->lock);
+      }
+    }
+
+    if(earliest) {
+      earliest->state = RUNNING;
+      c->proc = earliest;
+      swtch(&c->context, &earliest->context);
+      c->proc = 0;
+      acquire(&earliest->lock);
+      release(&earliest->lock);
+    } else {
+      asm volatile("wfi");
+    }
+
+#elif defined(CFS)
+    struct proc *p;
+    struct proc *selected = 0;
+
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        if(!selected || p->vruntime < selected->vruntime) {
+          if(selected) release(&selected->lock);
+          selected = p;
+        } else {
+          release(&p->lock);
+        }
+      } else {
+        release(&p->lock);
+      }
+    }
+
+    if(selected) {
+      int runnable_count = 0;
+      for(struct proc *q = proc; q < &proc[NPROC]; q++) {
+        acquire(&q->lock);
+        if(q->state == RUNNABLE) runnable_count++;
+        release(&q->lock);
+      }
+
+      int time_slice = 48 / runnable_count;
+      if(time_slice < 3) time_slice = 3;
+
+      printf("[Scheduler Tick]\n");
+      for(struct proc *q = proc; q < &proc[NPROC]; q++) {
+        acquire(&q->lock);
+        if(q->state == RUNNABLE)
+          printf("PID: %d | vRuntime: %lu\n", q->pid, q->vruntime);
+        release(&q->lock);
+      }
+      printf("--> Scheduling PID %d (lowest vRuntime)\n", selected->pid);
+
+      selected->state = RUNNING;
+      c->proc = selected;
+      swtch(&c->context, &selected->context);
+      c->proc = 0;
+
+      selected->vruntime += (time_slice * 1024) / selected->weight;
+
+      acquire(&selected->lock);
+      release(&selected->lock);
+    } else {
+      asm volatile("wfi");
+    }
+
+#else // Round Robin
+    struct proc *p;
     int found = 0;
+
     for(p = proc; p < &proc[NPROC]; p++) {
       acquire(&p->lock);
       if(p->state == RUNNABLE) {
-        // Switch to chosen process.  It is the process's job
-        // to release its lock and then reacquire it
-        // before jumping back to us.
         p->state = RUNNING;
         c->proc = p;
         swtch(&c->context, &p->context);
-
-        // Process is done running for now.
-        // It should have changed its p->state before coming back.
         c->proc = 0;
         found = 1;
       }
       release(&p->lock);
     }
+
     if(found == 0) {
-      // nothing to run; stop running on this core until an interrupt.
       asm volatile("wfi");
     }
+#endif
   }
